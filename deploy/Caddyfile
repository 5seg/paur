# Caddyfile for paur.
#
# Layout (after `webui` is populated; see `deploy/README.linux.md`):
#   /                 → static SvelteKit UI, served from <data_dir>/webui
#   /api/v1/*         → the daemon's HTTP API
#   /repo/$arch/*     → the published pacman repo (signed .pkg.tar.zst,
#                      paur.db.tar.gz, .sig, paur.pubkey.asc)
#
# Why two separate roots? `webui/` is owned by the deployer (the
# user running `npm run build` + rsync), while `repo/` is owned
# by the daemon's service user (paur) because the daemon writes
# package files and the repo DB into it. Mixing them in one
# directory caused a recurring crash: rsync would set the root to
# the deployer's uid, then the daemon could not create
# `repo/x86_64/` and died at startup.
#
# This file matches `deploy/Caddyfile.public` for behaviour
# (no ACME, TLS terminated in front by Cloudflare or another
# proxy). Caddy 2.6+ no longer accepts `auto_https on`; it wants
# an explicit off / disable_* / ignore_loaded_certs keyword. The
# earlier "on" form silently succeeded on 2.6.x pre-config, so
# the difference between the two files used to be a no-op; we
# now spell it the way 2.6+ wants.
#
# Adjust `root` and the bind address to taste. This config assumes
# the daemon is listening on the loopback fallback (127.0.0.1:7300)
# since axum 0.7 doesn't accept a unix listener. If you want a
# self-contained Caddy that fetches and renews its own Let's
# Encrypt cert, copy this file and add an `email` block inside
# the global `{ ... }` along with the hostnames you want to
# serve; Caddy will then ignore the `auto_https off` and run ACME
# on first request.

{
    auto_https off
    servers {
        protocols h1 h2c
    }
}

# Primary site. Replace `paur.example` with your hostname. Bare
# hostnames (no scheme) here mean "match this Host header on
# whatever port the listener is bound to". Writing the host with
# an `http://` prefix asks Caddy to treat it as a virtual host
# for HTTPS, which interacts badly with `auto_https off` and
# routes any other method on those hosts into the default site
# (which is empty here) — observed as GETs returning SPA
# index.html and PATCH / POST returning 404.
paur.example, localhost, xserver {
    # Where the SvelteKit `npm run build` output lives. This
    # directory is owned by the deployer (root or your user) and
    # only ever written by the deploy step. The daemon never
    # touches it; see the header comment for why we keep it
    # separate from `repo/`. Must be readable by the caddy user
    # (typically 0755 directories, 0644 files).
    root * /var/lib/paur/webui

    encode zstd gzip

    # Static repo files first — these are the actual packages and DB
    # that `pacman -Sy` fetches. We set short caching so a new build
    # is visible after the next `pacman -Sy`.
    @repo path /repo/*
    handle @repo {
        root * /var/lib/paur/repo
        file_server
        header Cache-Control "no-cache, must-revalidate"
    }

    # Daemon HTTP API (the SvelteKit UI talks to this through the
    # Vite dev proxy, and at runtime through this reverse proxy).
    @api path /api/*
    handle @api {
        reverse_proxy 127.0.0.1:7300 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            transport http {
                dial_timeout 5s
                # SSE log streams live up to an hour; don't time out.
                response_header_timeout 1h
            }
        }
    }

    # SvelteKit static assets — hashed bundle files under /_app,
    # favicon, etc. List any top-level asset directories the build
    # emits here. Anything not in this list and not /repo/* or
    # /api/* falls through to the SPA fallback below.
    @spaAssets path /_app/* /favicon.ico /assets/*
    handle @spaAssets {
        file_server
    }

    # SPA fallback: anything that isn't a real asset, repo file,
    # or API call gets rewritten to /index.html so SvelteKit's
    # client-side router can take over. This is what makes
    # `https://paur.example/packages/<name>` work on hard reload.
    @spaFallback not path /repo/* /api/* /_app/* /favicon.ico /assets/*
    handle @spaFallback {
        rewrite * /index.html
        file_server
    }
}
