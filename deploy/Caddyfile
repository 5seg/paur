# Caddyfile for paur.
#
# Layout (after `webui` is populated; see `deploy/README.linux.md`):
#   /                 → static SvelteKit UI, served from <data_dir>/webui
#   /api/v1/*         → the daemon's HTTP API
#   /repo/$arch/*     → the published pacman repo (signed .pkg.tar.zst,
#                      paur.db.tar.gz, .sig, paur.pubkey.asc)
#
# Why two separate roots? `webui/` is owned by the deployer (the
# user running `npm run build` + rsync), while `repo/` is owned
# by the daemon's service user (paur) because the daemon writes
# package files and the repo DB into it. Mixing them in one
# directory caused a recurring crash: rsync would set the root to
# the deployer's uid, then the daemon could not create
# `repo/x86_64/` and died at startup.
#
# This file matches `deploy/Caddyfile.public` for behaviour
# (no ACME, TLS terminated in front by Cloudflare or another
# proxy). Caddy 2.6+ no longer accepts `auto_https on`; it wants
# an explicit off / disable_* / ignore_loaded_certs keyword. The
# earlier "on" form silently succeeded on 2.6.x pre-config, so
# the difference between the two files used to be a no-op; we
# now spell it the way 2.6+ wants.
#
# Adjust `root` and the bind address to taste. This config assumes
# the daemon is listening on the loopback fallback (127.0.0.1:7300)
# since axum 0.7 doesn't accept a unix listener. If you want a
# self-contained Caddy that fetches and renews its own Let's
# Encrypt cert, copy this file and add an `email` block inside
# the global `{ ... }` along with the hostnames you want to
# serve; Caddy will then ignore the `auto_https off` and run ACME
# on first request.

{
    auto_https off
    servers {
        protocols h1 h2c
    }
}

# Bind :80 directly and match any Host header inside an explicit
# `@host` matcher. Caddy treats bare hostnames (`xserver`) as
# implicit HTTPS sites and binds only :443, leaving :80 closed;
# `http://xserver` works for the named host but routes other
# methods to the empty default site (we saw GET 200 / PATCH 404
# because the SPA fallback ate GETs but not PATCHes). `:80` with
# a Host matcher is the only form that handles every method on
# every host we serve.
:80 {
    # Per-path routing. We use `handle_path` for the file-serving
    # scopes because it strips the matched prefix from the request
    # path before delegating, which makes it impossible to leak a
    # parent-scope `root` into a child handle. `handle` + a child
    # `root` *should* work, but in practice Caddy 2.6+'s
    # `vars` semantics make it brittle when the parent also
    # sets `root`; using `handle_path` with the root set in the
    # same block is the bulletproof form.
    @hostnames host paur.example localhost xserver
    route @hostnames {
        encode zstd gzip

        # Static repo files first — these are the actual packages
        # and DB that `pacman -Sy` fetches. We set short caching
        # so a new build is visible after the next `pacman -Sy`.
        # `handle_path /repo` strips the /repo prefix from the
        # request, so the inner file_server looks for
        # `<root>/x86_64/<file>` directly.
        handle_path /repo/* {
            root * /var/lib/paur/repo
            file_server
            header Cache-Control "no-cache, must-revalidate"
        }

        # Daemon HTTP API (the SvelteKit UI talks to this through
        # the Vite dev proxy, and at runtime through this reverse
        # proxy). We use `handle` (not `handle_path`) here so the
        # full `/api/*` path is preserved when proxying — the
        # daemon's routes are mounted at `/api/v1/*` and would
        # 404 on `/v1/*`.
        @api path /api/*
        handle @api {
            reverse_proxy 127.0.0.1:7300 {
                header_up Host {host}
                header_up X-Real-IP {remote_host}
                transport http {
                    dial_timeout 5s
                    # SSE log streams live up to an hour; don't
                    # time out.
                    response_header_timeout 1h
                }
            }
        }

        # SvelteKit static assets — hashed bundle files under
        # /_app, favicon, etc. List any top-level asset
        # directories the build emits here. Anything not in this
        # list and not /repo/* or /api/* falls through to the SPA
        # fallback below.
        handle_path /_app/* {
            root * /var/lib/paur/webui
            file_server
        }
        handle_path /favicon.ico {
            root * /var/lib/paur/webui
            file_server
        }
        handle_path /assets/* {
            root * /var/lib/paur/webui
            file_server
        }

        # SPA fallback: anything that isn't a real asset, repo
        # file, or API call gets rewritten to /index.html so
        # SvelteKit's client-side router can take over. This is
        # what makes `https://paur.example/packages/<name>` work
        # on hard reload.
        handle {
            root * /var/lib/paur/webui
            rewrite * /index.html
            file_server
        }
    }
}
